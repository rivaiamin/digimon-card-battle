# Local development environment
# Copy to `.env` and fill in values. See README.md → "Run locally".
#
# Client Firebase config lives in firebase-applet-config.json (not here).
# Admin credentials below MUST be from the SAME Firebase project (e.g. raysaber).

# --- Firebase Admin (required for BattleRoom ID token verification) ---
# Provide ONE of the following from your target Firebase project:
# Firebase Console → Project settings → Service accounts → Generate new private key

# Option A: absolute path to the downloaded service account JSON (simplest locally)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/raysaber-serviceAccount.json

# Option B: inline JSON on one line (preferred if you already have GOOGLE_APPLICATION_CREDENTIALS
# set globally for another project — this repo reads FIREBASE_SERVICE_ACCOUNT_JSON first)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"raysaber",...}

# --- Optional ---

# Set to 0 to silence draw/deck-out debug logs from BattleRoom
# DEBUG_BATTLE_ROOM=0

# AI Studio sets this to disable Vite HMR during agent edits; leave unset for normal local dev
# DISABLE_HMR=true
